VITE_CLAUDE_API_KEY=

# Optional: route all model calls through the local proxy, which forwards them to the
# real Anthropic API authenticated with your Claude *subscription* (its OAuth token from
# the Claude Code login) instead of a metered API key. Same model, temperature 0, and
# system prompt as the API — i.e. identical behavior, just billed to the subscription.
# Start it with:  node scripts/cli-proxy.mjs   (listens on http://localhost:8787)
# Then set:       VITE_LLM_PROXY=http://localhost:8787
# When set, this takes precedence over VITE_CLAUDE_API_KEY for both the app and the live tests.
VITE_LLM_PROXY=
